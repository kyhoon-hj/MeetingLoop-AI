NODE_ENV=production
ALLOW_DEMO_ACCOUNT_HINTS=false
APP_URL=http://EC2_PUBLIC_IP:3101
APP_TIMEZONE=Asia/Seoul

# PostgreSQL on the same EC2 host. For RDS, replace host.docker.internal with the RDS endpoint.
DATABASE_URL=postgresql://postgres:change-me@host.docker.internal:5432/meeting
DATABASE_SSL=false
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
POSTGRES_OPS_VERSION=16
REDIS_URL=redis://redis:6379/0
ANALYSIS_QUEUE_MODE=redis
WORKER_CONCURRENCY=2
WORKER_JOB_TIMEOUT_MS=240000
WORKER_HEALTH_PORT=3001
RETENTION_SWEEP_ENABLED=false
RETENTION_SWEEP_INTERVAL_MS=3600000

# Generate with: openssl rand -base64 48
SESSION_SECRET=replace-with-long-random-value

# Original audio remains in the browser. Confirmed transcripts and minutes use PostgreSQL.
STORAGE_DRIVER=memory

# Choose ollama or gemini for production. mock is limited to development and CI.
ANALYSIS_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:4b

MAX_UPLOAD_BYTES=1073741824
AUDIO_RETENTION_DAYS=365
SIGNED_URL_TTL_SECONDS=900
