NODE_ENV=production
APP_URL=http://EC2_PUBLIC_IP:3101
APP_TIMEZONE=Asia/Seoul

DATABASE_URL=postgresql://postgres:change-me@host.docker.internal:5432/meeting
DATABASE_SSL=false
DB_POOL_MAX=10

# Generate with: openssl rand -base64 48
SESSION_SECRET=replace-with-long-random-value

# Demo deployment keeps application data in process memory.
STORAGE_DRIVER=memory

# Choose ollama, gemini, or mock. Gemini is easiest on a small EC2 instance.
ANALYSIS_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:4b

MAX_UPLOAD_BYTES=1073741824
AUDIO_RETENTION_DAYS=365
SIGNED_URL_TTL_SECONDS=900
